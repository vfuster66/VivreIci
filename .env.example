# Supabase
# Ces clés sont disponibles dans le dashboard de votre projet Supabase sous Settings > API
NEXT_PUBLIC_SUPABASE_URL="VOTRE_URL_SUPABASE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="VOTRE_CLE_ANONYME_SUPABASE"

# Resend (pour l'envoi d'emails)
RESEND_API_KEY="VOTRE_CLE_API_RESEND"

# Supabase service role (pour les cron jobs / agrégations serveur)
SUPABASE_SERVICE_ROLE_KEY="VOTRE_SERVICE_ROLE_KEY_SUPABASE"

# Application / cron hebdo
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="UN_SECRET_POUR_SECURISER_LE_CRON"
SUPERADMIN_USER="superadmin@example.com"
WEEKLY_REPORTS_TEST_MODE="true"
WEEKLY_REPORTS_TEST_EMAIL="vous@example.com"
WEEKLY_REPORTS_CITY_EMAIL="mairie@example.com"
WEEKLY_REPORTS_FROM_EMAIL="noreply@vivreici.app"
WEEKLY_REPORTS_REPLY_TO="contact@vivreici.app"
VIVREICI_DEFAULT_CITY="Cabestany"
VIVREICI_CONTACT_EMAIL="contact@vivreici.app"
